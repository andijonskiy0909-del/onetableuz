# Node
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:pass@postgres:5432/onetable
DATABASE_SSL=false

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=change_this_in_production
JWT_EXPIRES_IN=30d

# Telegram
BOT_TOKEN=1234567890:ABCdefGHIJklmNOPqrstUVwxyz
WEBAPP_URL=https://yourdomain.com
API_URL=https://api.yourdomain.com

# Groq AI
GROQ_API_KEY=your_groq_api_key

# Payme
PAYME_MERCHANT_ID=your_merchant_id
PAYME_KEY=your_key
PAYME_URL=https://checkout.paycom.uz

# Click
CLICK_SERVICE_ID=your_service_id
CLICK_MERCHANT_ID=your_merchant_id
CLICK_SECRET=your_secret

# Admin
ADMIN_EMAIL=admin@onetable.uz
ADMIN_PASSWORD_HASH=bcrypt_hash  # generate with bcrypt.hash('admin123', 10)  shun qayerga yozishim kerak edi
