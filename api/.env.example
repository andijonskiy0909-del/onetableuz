# ── Server ─────────────────────────────
PORT=3000
NODE_ENV=production
APP_URL=https://your-backend.up.railway.app

# ── Database ───────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/onetable

# ── JWT ────────────────────────────────
JWT_SECRET=change_this_to_long_random_string_at_least_48_chars
JWT_EXPIRES_IN=30d

# ── Telegram Bot ───────────────────────
BOT_TOKEN=123456:AAA-your-bot-token
WEBHOOK_URL=https://your-backend.up.railway.app
WEBAPP_URL=https://your-backend.up.railway.app/app
API_URL=https://your-backend.up.railway.app/api

# ── AI (optional) ──────────────────────
GROQ_API_KEY=gsk_...

# ── Uploads ────────────────────────────
UPLOAD_MAX_IMAGE_MB=8
UPLOAD_MAX_VIDEO_MB=80

# ── CORS ───────────────────────────────
CORS_ORIGINS=*
