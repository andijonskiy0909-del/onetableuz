# ── Server ─────────────────────────────
PORT=3000
NODE_ENV=production
APP_URL=https://your-app.up.railway.app

# ── Database ───────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/onetable

# ── JWT ────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_at_least_48_chars_long_here
JWT_EXPIRES_IN=30d

# ── Telegram Bot ───────────────────────
BOT_TOKEN=123456:AAA-your-bot-token
WEBHOOK_URL=https://your-app.up.railway.app
WEBAPP_URL=https://your-app.up.railway.app/app
API_URL=https://your-app.up.railway.app/api

# ── AI (Groq — optional) ──────────────
GROQ_API_KEY=gsk_...

# ── Uploads ────────────────────────────
UPLOAD_MAX_IMAGE_MB=8
UPLOAD_MAX_VIDEO_MB=80

# ── Admin seed ─────────────────────────
ADMIN_EMAIL=admin@onetable.uz
ADMIN_PASSWORD=changeme123
